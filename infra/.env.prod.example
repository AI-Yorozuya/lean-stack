# 複製成 infra/.env.prod 後填入正式值（infra/.env.prod 已被 gitignore）。
# 這些值同時給 docker-compose.prod.yml 的 postgres / backend / celery-worker 用。
# 機密只活在這個檔（與環境變數）裡，絕不進版控。

# --- Postgres ---
POSTGRES_DB=lean_stack
POSTGRES_USER=lean_stack
POSTGRES_PASSWORD=CHANGE-ME-strong-password

# --- Django backend ---
# host 用 compose 的 service 名 postgres；帳密要跟上面一致。
DATABASE_URL=postgres://lean_stack:CHANGE-ME-strong-password@postgres:5432/lean_stack
DJANGO_SECRET_KEY=CHANGE-ME-to-a-long-random-string
DEBUG=False

# 非同步任務 redis broker（backend + celery-worker 共用）。compose 內用 service 名 redis。
CELERY_BROKER_URL=redis://redis:6379/0

# DEBUG=False 時必填（逗號分隔）。前台 + 後台網域都要列。
ALLOWED_HOSTS=your-domain.com,admin.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# --- media 上傳：prod 用 S3 ---
# 憑證走 EC2 instance role / 環境變數，不寫這裡。bucket 名對齊 terraform 的 media_bucket_name。
USE_S3=True
AWS_STORAGE_BUCKET_NAME=lean-stack-media
AWS_S3_REGION_NAME=ap-northeast-1
