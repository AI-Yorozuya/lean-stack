# 複製成 terraform.tfvars 後填入實際值（terraform.tfvars 已被 gitignore）。
# 這裡只放「非機密」設定；真正的雲憑證走環境變數（見 README / DEPLOY）。

project_name     = "lean-stack"
aws_region       = "ap-northeast-1"
instance_type    = "t3.small"

# 先在 AWS console 建好一個 EC2 Key Pair，把名字填這裡。
key_name         = "your-ec2-keypair-name"

# 強烈建議鎖成你自己的對外 IP，例如 "203.0.113.7/32"，別用 0.0.0.0/0。
ssh_cidr         = "0.0.0.0/0"

root_volume_size = 30
