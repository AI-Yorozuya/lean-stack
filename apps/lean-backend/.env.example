# 複製成 .env 後填入實際值（.env 已被 gitignore，不會進版控）。
# 本機若用 docker compose，這些值由 docker-compose.local.yml 注入，可不必另設 .env。

# 資料庫連線字串：postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lean_stack

# 非同步任務的 redis broker（celery）。docker compose 內用 service 名 redis。
CELERY_BROKER_URL=redis://localhost:6379/0

# Django 密鑰（正式環境務必換成隨機長字串，別外流）。
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# 開發開 True；正式環境設 False。
DEBUG=True

# DEBUG=False 時才會用到的兩個白名單（逗號分隔）：
# ALLOWED_HOSTS=example.com,www.example.com
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# 上傳檔存哪：本機開發用 False（存本機 /media，零摩擦）。
USE_S3=False
# USE_S3=True 時才需要（憑證走環境變數 / EC2 instance role，不寫這裡）：
# AWS_STORAGE_BUCKET_NAME=your-media-bucket
# AWS_S3_REGION_NAME=ap-northeast-1
