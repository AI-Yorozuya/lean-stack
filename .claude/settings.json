{
  "$comment": "lean-stack 新手護欄（跟著 repo 走，git clone 下來就生效）。三層：allow=快樂路徑零彈窗；deny=單向門直接擋；hooks/guard.sh=deny 字串比對漏掉的變體由它攔。設計原則見 CLAUDE.md「危險操作護欄」。",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(docker compose *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npx shadcn-vue*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(curl http://localhost*)",
      "Bash(curl -s http://localhost*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean *)",
      "Bash(git branch -D *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/guard.sh\""
          }
        ]
      }
    ]
  }
}
